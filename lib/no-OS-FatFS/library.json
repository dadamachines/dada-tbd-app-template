{
  "name": "no-OS-FatFS",
  "version": "1.0.0",
  "description": "FatFS + SDIO PIO driver for RP2040/RP2350",
  "frameworks": "picosdk",
  "platforms": "raspberrypi",
  "build": {
    "srcFilter": [
      "+<ff15/source/ff.c>",
      "+<ff15/source/ffsystem.c>",
      "+<ff15/source/ffunicode.c>",
      "+<sd_driver/dma_interrupts.c>",
      "+<sd_driver/sd_card.c>",
      "+<sd_driver/sd_timeouts.c>",
      "+<sd_driver/SDIO/rp2040_sdio.c>",
      "+<sd_driver/SDIO/sd_card_sdio.c>",
      "+<sd_driver/SPI/my_spi.c>",
      "+<sd_driver/SPI/sd_card_spi.c>",
      "+<sd_driver/SPI/sd_spi.c>",
      "+<src_impl/crash.c>",
      "+<src_impl/crc.c>",
      "+<src_impl/f_util.c>",
      "+<src_impl/ff_stdio.c>",
      "+<src_impl/file_stream.c>",
      "+<src_impl/glue.c>",
      "+<src_impl/my_debug.c>",
      "+<src_impl/my_rtc.c>",
      "+<src_impl/util.c>"
    ],
    "includeDir": "include",
    "flags": [
      "-Iff15/source",
      "-Isd_driver",
      "-Isd_driver/SDIO"
    ]
  }
}
